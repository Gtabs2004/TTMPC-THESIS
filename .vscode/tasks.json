{
  "version": "2.0.0",
  "tasks": [

    {
      "label": "Frontend: Vite Dev",
      "type": "npm",
      "script": "dev",
      "path": "TTMPC_THESIS",
      "isBackground": true,
      "presentation": {
        "panel": "dedicated",
        "group": "ttmpc",
        "reveal": "always",
        "clear": false
      },
      "problemMatcher": []
    },

    {
      "label": "Backend: FastAPI (venv)",
      "type": "shell",
      "command": "${workspaceFolder}/TTMPC_THESIS/src/server/.venv/Scripts/python.exe",
      "args": [
        "-m",
        "uvicorn",
        "main:app",
        "--reload",
        "--app-dir",
        "${workspaceFolder}/TTMPC_THESIS/src/server"
      ],
      "options": {
        "cwd": "${workspaceFolder}/TTMPC_THESIS/src/server"
      },
      "isBackground": true,
      "presentation": {
        "panel": "dedicated",
        "group": "ttmpc",
        "reveal": "always",
        "clear": false
      },
      "problemMatcher": []
    },

    {
      "label": "Start Full Stack",
      "dependsOn": [
        "Frontend: Vite Dev",
        "Backend: FastAPI (venv)"
      ],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "panel": "shared",
        "reveal": "always"
      },
      "problemMatcher": []
    }

  ]
}
